{
  "name": "trustdelivery-admin",
  "version": "1.0.0",
  "description": "TrustDelivery Admin Panel - Logistics management platform for Yaoundé, Cameroon",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "backend": "cd backend && cargo run",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && cargo build",
    "db:migrate": "psql -f backend/migrations/001_initial_schema.sql",
    "db:seed": "psql -f backend/migrations/002_seed_data.sql"
  },
  "keywords": [
    "logistics",
    "delivery",
    "cameroon",
    "yaounde",
    "admin-panel",
    "rust",
    "react",
    "typescript"
  ],
  "author": "TrustDelivery Team",
  "license": "MIT"
}